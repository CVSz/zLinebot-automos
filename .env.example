DOMAIN=zlinebot-automos.local
DB_PASS=change_me_db_password
REDIS_PASS=change_me_redis_password
JWT_SECRET_CURRENT=change_me_jwt_secret_current
JWT_SECRET_PREVIOUS=
KAFKA_USER=zlinebot_app
KAFKA_PASS=change_me_kafka_password
ADMIN_PASS=change_me_admin_password
OPENAI_API_KEY=REPLACE
CERT_EMAIL=admin@zlinebot-automos.local
CLOUDFLARED_TUNNEL_ID=replace-with-your-tunnel-uuid
DATABASE_URL=postgresql://zlinebot:${DB_PASS}@db:5432/zlinebot_automos
REDIS_URL=redis://:${REDIS_PASS}@redis:6379/0
KAFKA_BROKER=kafka:9092
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_USERNAME=${KAFKA_USER}
KAFKA_PASSWORD=${KAFKA_PASS}
