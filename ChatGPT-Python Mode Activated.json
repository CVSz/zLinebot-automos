// store decisions
export function logTrade(decision, price) {
  const db = load();
  db.push({
    decision,
    price,
    time: Date.now()
  });
  save(db);
}

// evaluate performance
export function evaluate() {
  const db = load();

  let score = 0;

  for (let i = 1; i < db.length; i++) {
    const prev = db[i-1];
    const curr = db[i];

    if (prev.decision === "BUY" && curr.price > prev.price) score++;
    if (prev.decision === "SELL" && curr.price < prev.price) score++;
  }

  return score;
}



