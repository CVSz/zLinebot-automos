import torch
import torch.nn as nn

class OrderBookNet(nn.Module):
    def __init__(self):
        super().__init__()
        self.lstm = nn.LSTM(input_size=20, hidden_size=64, batch_first=True)
        self.fc = nn.Linear(64, 3)

    def forward(self, x):
        out,_ = self.lstm(x)
        out = out[:, -1, :]
        return self.fc(out)



