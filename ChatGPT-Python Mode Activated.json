#!/bin/bash

echo "🚀 Installing zBAutomos..."

PROJECT="zBAutomos"

mkdir -p $PROJECT/{api,ai,trading,workers,dashboard,memory,config}

cd $PROJECT || exit

# ================================
# PACKAGE.JSON
# ================================
cat > package.json <<EOF
{
  "name": "zBAutomos",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "socket.io": "^4.7.2",
    "ioredis": "^5.3.2",
    "bullmq": "^4.10.0",
    "technicalindicators": "^3.1.0"
  }
}
EOF

# ================================
# BASIC SERVER
# ================================
cat > api/server.js <<'EOF'
import express from "express";

const app = express();
app.use(express.json());

app.get("/", (req,res)=>res.send("zBAutomos running"));

app.listen(3000, ()=>console.log("🚀 API running on 3000"));
EOF

# ================================
# AI MODULE
# ================================
cat > ai/ai.js <<'EOF'
export async function askAI(msg) {
  return "AI response: " + msg;
}
EOF

# ================================
# MEMORY
# ================================
cat > memory/memory.js <<'EOF'
let mem = [];

export function save(msg) {
  mem.push(msg);
}

export function get() {
  return mem.slice(-10);
}
EOF

# ================================
# TRADING ENGINE
# ================================
cat > trading/engine.js <<'EOF'
export function runEngine() {
  console.log("📈 Trading engine running...");
}
EOF

# ================================
# WORKER
# ================================
cat > workers/worker.js <<'EOF'
console.log("🤖 Worker started");
EOF

# ================================
# DOCKERFILE
# ================================
cat > dockerfile <<EOF
FROM node:20
WORKDIR /app
COPY . .
RUN npm install
CMD ["node","api/server.js"]
EOF

# ================================
# INSTALL DEPENDENCIES
# ================================
npm install

# ================================
# ZIP PROJECT
# ================================
cd ..
zip -r zBAutomos.zip zBAutomos

echo "✅ DONE!"
echo "📦 File created: zBAutomos.zip"



