  const last = prices[prices.length-1];

  if (last < avg * 0.98) return "BUY";
  if (last > avg * 1.02) return "SELL";
  return "HOLD";
}



📄 portfolio.js (decision engine)


import { rsiStrategy, macdStrategy, meanReversion } from "./strategies.js";

export function decide(prices) {
  const votes = [
    rsiStrategy(prices),
    macdStrategy(prices),
    meanReversion(prices)
  ];

  const score = votes.reduce((acc, v) => {
    if (v === "BUY") acc++;
    if (v === "SELL") acc--;
    return acc;
  }, 0);

  if (score > 1) return "BUY";
  if (score < -1) return "SELL";
  return "HOLD";
}


👉 This mimics hedge fund signal aggregation



