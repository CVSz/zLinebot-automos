💻 🔥 ONE-COMMAND INSTALL SCRIPT (Linux / Mac)


# ================================
# CODEX ULTRA SETUP SCRIPT
# ================================

echo "⚡ Installing Codex CLI..."
npm install -g @openai/codex

echo "📁 Creating config directory..."
mkdir -p ~/.codex

echo "⚙️ Writing advanced config..."

cat > ~/.codex/config.toml << 'EOF'

# ================================
# CORE MODEL SETTINGS
# ================================
model = "gpt-5.3-codex"
model_reasoning_effort = "high"   # max intelligence
approval_policy = "never"         # full auto mode
sandbox_mode = "workspace-write"  # safe + powerful

# ================================
# PERFORMANCE OPTIMIZATION
# ================================
context_compression = true
parallel_tasks = true
max_threads = 8
cache_enabled = true

# ================================
# BEHAVIOR SETTINGS
# ================================
auto_fix_errors = true
auto_install_dependencies = true
auto_run_tests = true

# ================================
# SHELL CONTROL
# ================================
[shell_environment_policy]
inherit = "all"
set = { CI = "1", NODE_ENV = "production" }

# ================================
# PROFILES (MULTI-MODE)
# ================================
[profiles.fast]
model = "o4-mini"
model_reasoning_effort = "low"

[profiles.brain]
model = "gpt-5.3-codex"
model_reasoning_effort = "high"

[profiles.safe]
approval_policy = "on-request"
sandbox_mode = "read-only"

EOF

echo "🔑 Set your API key:"
echo "export OPENAI_API_KEY='your-api-key-here'" >> ~/.bashrc

echo "✅ Setup complete!"
echo "Run: codex --full-auto"



