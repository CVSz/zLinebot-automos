📄 execution/engine.js


export async function smartExecute(side, size, price, exchange) {
  const MAX_SLIPPAGE = 0.002; // 0.2%
  const orderBook = await exchange.getOrderBook();

  const best = side === "buy" ? orderBook.ask : orderBook.bid;
  const slippage = Math.abs((best - price) / price);

  if (slippage > MAX_SLIPPAGE) {
    console.log("❌ Slippage too high, skipping");
    return;
  }

  return exchange.limitOrder(side, size, best);
}



🔥 TWAP (time-sliced execution)


export async function twapOrder(side, totalSize, slices=5) {
  const size = totalSize / slices;

  for (let i = 0; i < slices; i++) {
    await smartExecute(side, size);
    await new Promise(r => setTimeout(r, 2000));
  }
}



