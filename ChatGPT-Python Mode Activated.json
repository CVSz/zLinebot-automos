📄 backtest/engine.js


export class BacktestEngine {
  constructor(strategy, data) {
    this.strategy = strategy;
    this.data = data;
    this.balance = 10000;
    this.position = 0;
    this.trades = [];
  }

  run() {
    for (let i = 0; i < this.data.length; i++) {
      const candle = this.data[i];
      const signal = this.strategy(candle, this);

      if (signal === "BUY" && this.position === 0) {
        this.position = this.balance / candle.price;
        this.balance = 0;
        this.trades.push({ type: "BUY", price: candle.price });
      }

      if (signal === "SELL" && this.position > 0) {
        this.balance = this.position * candle.price;
        this.position = 0;
        this.trades.push({ type: "SELL", price: candle.price });
      }
    }

    return this.results();
  }

  results() {
    return {
      balance: this.balance,
      trades: this.trades
    };
  }
}



