import { BacktestEngine } from "../backtest/engine.js";
import { strategy } from "../strategy/advanced.js";
import { executeTrade } from "../execution/live.js";

export async function tradingLoop(marketData) {
  // 1. backtest
  const backtest = new BacktestEngine(strategy, marketData);
  const result = backtest.run();

  console.log("📊 Backtest:", result.balance);

  // 2. validate
  if (result.balance > 11000) {
    console.log("✅ Strategy approved → LIVE");

    // 3. live trading
    for (let tick of marketData.slice(-50)) {
      const signal = strategy(tick);

      if (signal !== "HOLD") {
        await executeTrade(signal);
      }
    }
  } else {
    console.log("❌ Strategy rejected");
  }
}



