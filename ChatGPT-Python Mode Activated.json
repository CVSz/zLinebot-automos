🚀 FULL AUTO SETUP SCRIPT (ALL-IN-ONE)


💻 Linux / Mac


#!/bin/bash

echo "🚀 FULL CODEX AUTO SETUP (zLinebot-automos)"

# ================================
# 1. CLONE REPO
# ================================
if [ ! -d "zLinebot-automos" ]; then
  echo "📥 Cloning repository..."
  git clone https://github.com/CVSz/zLinebot-automos.git
fi

cd zLinebot-automos || exit

# ================================
# 2. DETECT PROJECT TYPE
# ================================
echo "🧠 Detecting project type..."

if [ -f package.json ]; then
  TYPE="node"
elif [ -f requirements.txt ]; then
  TYPE="python"
elif [ -f go.mod ]; then
  TYPE="go"
else
  TYPE="unknown"
fi

echo "📦 Project type: $TYPE"

# ================================
# 3. INSTALL DEPENDENCIES
# ================================
echo "📦 Installing dependencies..."

if [ "$TYPE" = "node" ]; then
  npm install
elif [ "$TYPE" = "python" ]; then
  pip install -r requirements.txt
elif [ "$TYPE" = "go" ]; then
  go mod tidy
fi

# ================================
# 4. CREATE ENV FILE
# ================================
if [ ! -f .env ]; then
cat > .env <<EOF
LINE_CHANNEL_ACCESS_TOKEN=PUT_YOUR_TOKEN_HERE
LINE_CHANNEL_SECRET=PUT_YOUR_SECRET_HERE
PORT=3000
NODE_ENV=production
EOF
echo "🔑 .env created (EDIT THIS!)"
fi

# ================================
# 5. CREATE RUN SCRIPT
# ================================
cat > run.sh <<'EOF'
#!/bin/bash

echo "🚀 Starting bot..."

if [ -f package.json ]; then
  npm start || node index.js || node app.js
elif [ -f app.py ]; then
  python app.py
elif [ -f main.go ]; then
  go run main.go
else
  echo "❌ No entry point found"
fi
EOF

chmod +x run.sh

# ================================
# 6. INSTALL CODEX
# ================================
echo "⚡ Installing Codex..."
npm install -g @openai/codex

# ================================
# 7. CONFIGURE CODEX
# ================================
mkdir -p ~/.codex

cat > ~/.codex/config.toml <<EOF
model = "gpt-5.3-codex"
model_reasoning_effort = "high"
approval_policy = "on-request"
sandbox_mode = "workspace-write"

auto_fix_errors = true
auto_install_dependencies = true
auto_run_tests = true

parallel_tasks = true
cache_enabled = true

[profiles.fast]
model = "o4-mini"
model_reasoning_effort = "low"
EOF

# ================================
# 8. VERIFY API KEY
# ================================
if [ -z "$OPENAI_API_KEY" ]; then
  echo "⚠️ No API key found!"
  echo "Run:"
  echo "export OPENAI_API_KEY=your_key_here"
fi

# ================================
# 9. RUN CODEX AUTO FIX
# ================================
echo "🤖 Running Codex auto setup..."

codex --auto-edit "
analyze this LINE bot project,
fix all errors,
install missing dependencies,
setup webhook,
optimize performance,
prepare production
"

# ================================
# 10. START BOT
# ================================
echo "🚀 Launching bot..."
./run.sh

echo "✅ DONE"



