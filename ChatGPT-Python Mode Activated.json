import fs from "fs";
import OpenAI from "openai";

const FILE = "./cluster.json";
const openai = process.env.OPENAI_API_KEY
  ? new OpenAI({ apiKey: process.env.OPENAI_API_KEY })
  : null;

function load() {
  if (!fs.existsSync(FILE)) return [];
  return JSON.parse(fs.readFileSync(FILE));
}

function save(data) {
  fs.writeFileSync(FILE, JSON.stringify(data, null, 2));
}

function cosine(a, b) {
  let dot = 0, na = 0, nb = 0;
  for (let i = 0; i < a.length; i++) {
    dot += a[i]*b[i];
    na += a[i]*a[i];
    nb += b[i]*b[i];
  }
  return dot / (Math.sqrt(na)*Math.sqrt(nb));
}

async function embed(text) {
  if (!openai) return null;
  const r = await openai.embeddings.create({
    model: "text-embedding-3-small",
    input: text
  });
  return r.data[0].embedding;
}

// ---- CLUSTER SAVE ----
export async function saveCluster(text) {
  const db = load();
  const emb = await embed(text);

  let best = null;
  let bestScore = 0;

  for (let c of db) {
    const s = cosine(c.emb, emb);
    if (s > bestScore) {
      bestScore = s;
      best = c;
    }
  }

  if (best && bestScore > 0.8) {
    best.items.push(text);
  } else {
    db.push({ emb, items: [text] });
  }

  save(db);
}

// ---- RETRIEVE ----
export async function recall(query) {
  const db = load();
  const qEmb = await embed(query);

  return db
    .map(c => ({
      items: c.items,
      score: cosine(c.emb, qEmb)
    }))
    .sort((a,b)=>b.score-a.score)
    .slice(0,2)
    .flatMap(c=>c.items.slice(-3));
}


