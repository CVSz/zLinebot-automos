import { advancedStrategy } from "./strategy.js";

export function backtest(prices) {
  let balance = 1000;
  let position = 0;

  for (let i = 30; i < prices.length; i++) {
    const slice = prices.slice(i - 30, i);
    const price = prices[i];

    const action = advancedStrategy(slice);

    if (action === "BUY" && balance > 0) {
      position = balance / price;
      balance = 0;
    }

    if (action === "SELL" && position > 0) {
      balance = position * price;
      position = 0;
    }
  }

  const finalValue = balance + position * prices[prices.length - 1];

  return {
    start: 1000,
    end: finalValue,
    profit: finalValue - 1000
  };
}



