🚀 FIXED SCRIPT: runner_ultra_v4.2.sh


#!/bin/bash
# =========================================================
# 🚀 RUNNER ULTRA V4.2 (ENTERPRISE HARDENED)
# =========================================================

set -Eeuo pipefail

########################################
# CONFIG
########################################
RUNNER_USER="zeazdev"
PROJECT_ROOT="${PROJECT_ROOT:-/home/zeazdev/zLinebot-automos}"
REPO="${REPO:-CVSz/zLinebot-automos}"
RUNNER_NAME="${RUNNER_NAME:-ultra-runner}"
GITHUB_PAT="${GITHUB_PAT:-""}"
EPHEMERAL="${EPHEMERAL:-false}"

BASE_DIR="${PROJECT_ROOT}/.runners"
ACTIVE_LINK="${BASE_DIR}/current"
STATE_DIR="${PROJECT_ROOT}/.runner-state"
LOCK_FILE="/tmp/runner-ultra.lock"

SERVICE="actions.runner.${RUNNER_NAME}.service"

########################################
# UTILS
########################################
fail(){ echo "[❌] $1"; exit 1; }
ok(){ echo "[✅] $1"; }

retry() {
  local n=0
  until [ $n -ge 5 ]; do
    "$@" && return 0
    n=$((n+1))
    sleep 2
  done
  return 1
}

########################################
# VALIDATION
########################################
[[ $EUID -eq 0 ]] || fail "Run as root"
[[ -n "$GITHUB_PAT" ]] || fail "Missing GITHUB_PAT"

mkdir -p "$BASE_DIR" "$STATE_DIR"

########################################
# DEPS (STRICT)
########################################
apt-get update -y
apt-get install -y curl jq tar git coreutils

########################################
# USER
########################################
id "$RUNNER_USER" &>/dev/null || useradd -m -s /bin/bash "$RUNNER_USER"

########################################
# RESOURCE CHECK (PRODUCTION SAFETY)
########################################
FREE_MEM=$(free -m | awk '/Mem:/ {print $7}')
[[ "$FREE_MEM" -lt 512 ]] && fail "Low memory (<512MB)"

FREE_DISK=$(df / | awk 'NR==2 {print $4}')
[[ "$FREE_DISK" -lt 1048576 ]] && fail "Low disk (<1GB)"

########################################
# GET RUNNER VERSION (SAFE)
########################################
echo "[+] Fetching latest runner..."

API_JSON=$(retry curl -s https://api.github.com/repos/actions/runner/releases/latest) || fail "GitHub API failed"

URL=$(echo "$API_JSON" | jq -r '.assets[] | select(.name|test("linux-x64")) | .browser_download_url' | head -n1)

[[ -z "$URL" || "$URL" == "null" ]] && fail "Failed to parse runner URL"

VERSION=$(echo "$URL" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')
TARGET_DIR="${BASE_DIR}/runner-${VERSION}"

########################################
# INSTALL RUNNER (WITH ROLLBACK)
########################################
if [[ ! -d "$TARGET_DIR" ]]; then
  echo "[+] Installing runner $VERSION"

  TMP_DIR=$(mktemp -d)
  retry curl -L "$URL" -o "$TMP_DIR/runner.tar.gz" || fail "Download failed"

  tar tzf "$TMP_DIR/runner.tar.gz" > /dev/null || fail "Corrupt archive"

  mkdir -p "$TARGET_DIR"
  tar xzf "$TMP_DIR/runner.tar.gz" -C "$TARGET_DIR"

  chmod +x "$TARGET_DIR"/*.sh
  chown -R $RUNNER_USER:$RUNNER_USER "$TARGET_DIR"

  rm -rf "$TMP_DIR"
fi

########################################
# SAFE SWITCH
########################################
systemctl stop $SERVICE || true
ln -sfn "$TARGET_DIR" "$ACTIVE_LINK"
RUNNER_DIR="$ACTIVE_LINK"

ok "Active runner → $RUNNER_DIR"

########################################
# TOKEN (SAFE)
########################################
TOKEN=$(retry curl -s -X POST \
  -H "Authorization: token $GITHUB_PAT" \
  -H "Accept: application/vnd.github+json" \
  https://api.github.com/repos/$REPO/actions/runners/registration-token \
  | jq -r .token)

[[ "$TOKEN" == "null" || -z "$TOKEN" ]] && fail "Invalid token"

########################################
# CONFIGURE (ONLY IF NEEDED)
########################################
if [[ ! -f "$RUNNER_DIR/.runner" ]]; then
  echo "[+] Configuring runner..."

  WORK_DIR="${BASE_DIR}/work-${RUNNER_NAME}"
  mkdir -p "$WORK_DIR"
  chown -R $RUNNER_USER:$RUNNER_USER "$WORK_DIR"

  sudo -u $RUNNER_USER bash <<EOF
cd "$RUNNER_DIR"
./config.sh \
  --url https://github.com/$REPO \
  --token "$TOKEN" \
  --name "$RUNNER_NAME" \
  --work "$WORK_DIR" \
  $( [[ "$EPHEMERAL" == "true" ]] && echo "--ephemeral" ) \
  --unattended --replace
EOF
fi

[[ -f "$RUNNER_DIR/.runner" ]] || fail "Runner config failed"

########################################
# SYSTEMD (FIXED HARDENING)
########################################
cat > /etc/systemd/system/$SERVICE <<EOF
[Unit]
Description=Runner Ultra V4.2 ($RUNNER_NAME)
After=network.target

[Service]
User=$RUNNER_USER
WorkingDirectory=$RUNNER_DIR
ExecStart=/bin/bash $RUNNER_DIR/runsvc.sh

Restart=always
RestartSec=5

# safer hardening
NoNewPrivileges=true
PrivateTmp=true

# allow required paths
ReadWritePaths=$PROJECT_ROOT /tmp /var/tmp

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable $SERVICE

########################################
# HEALTH ENGINE (ATOMIC LOCK)
########################################
cat > /usr/local/bin/runner-health.sh <<EOF
#!/bin/bash

LOCK="$LOCK_FILE"
SERVICE="$SERVICE"
SCRIPT="$PROJECT_ROOT/scripts/runner_ultra_v4.2.sh"
LINK="$ACTIVE_LINK"

exec 9>\$LOCK || exit 0
flock -n 9 || exit 0

if [[ ! -f "\$LINK/run.sh" ]]; then
  echo "[HEALTH] broken → redeploy"
  systemctl stop \$SERVICE || true
  bash "\$SCRIPT"
  exit 0
fi

if ! systemctl is-active --quiet \$SERVICE; then
  systemctl restart \$SERVICE
fi
EOF

chmod +x /usr/local/bin/runner-health.sh

########################################
# TIMER
########################################
cat > /etc/systemd/system/runner-health.timer <<EOF
[Timer]
OnBootSec=1min
OnUnitActiveSec=1min
Unit=runner-health.service

[Install]
WantedBy=timers.target
EOF

cat > /etc/systemd/system/runner-health.service <<EOF
[Service]
Type=oneshot
ExecStart=/usr/local/bin/runner-health.sh
EOF

systemctl daemon-reload
systemctl enable runner-health.timer
systemctl start runner-health.timer

########################################
# START
########################################
systemctl start $SERVICE
