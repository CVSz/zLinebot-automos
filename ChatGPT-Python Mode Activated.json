📄 trading/rl_agent.js


export class RLAgent {
  constructor() {
    this.q = {}; // Q-table
    this.alpha = 0.1;
    this.gamma = 0.9;
    this.epsilon = 0.2;
  }

  getState(data) {
    return JSON.stringify({
      rsi: Math.round(data.rsi),
      trend: data.trend > 0 ? "UP" : "DOWN"
    });
  }

  chooseAction(state) {
    if (Math.random() < this.epsilon) {
      return ["BUY", "SELL", "HOLD"][Math.floor(Math.random()*3)];
    }

    return this.q[state]?.best || "HOLD";
  }

  update(state, action, reward, nextState) {
    const old = this.q[state]?.[action] || 0;
    const nextMax = Math.max(...Object.values(this.q[nextState] || { HOLD: 0 }));

    const newVal = old + this.alpha * (reward + this.gamma * nextMax - old);

    this.q[state] = this.q[state] || {};
    this.q[state][action] = newVal;
    this.q[state].best = Object.keys(this.q[state]).reduce((a,b)=>
      this.q[state][a] > this.q[state][b] ? a : b
    );
  }
}



