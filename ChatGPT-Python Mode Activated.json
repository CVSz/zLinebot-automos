📄 hybridMemory.js


import fs from "fs";
import OpenAI from "openai";

const FILE = "./memory.json";
const openai = process.env.OPENAI_API_KEY
  ? new OpenAI({ apiKey: process.env.OPENAI_API_KEY })
  : null;

function load() {
  if (!fs.existsSync(FILE)) return {};
  return JSON.parse(fs.readFileSync(FILE));
}

function save(data) {
  fs.writeFileSync(FILE, JSON.stringify(data, null, 2));
}

function keywordScore(text, query) {
  let s = 0;
  query.split(" ").forEach(w => {
    if (text.toLowerCase().includes(w.toLowerCase())) s++;
  });
  return s;
}

// ---- EMBEDDINGS ----
async function embed(text) {
  if (!openai) return null;
  const res = await openai.embeddings.create({
    model: "text-embedding-3-small",
    input: text
  });
  return res.data[0].embedding;
}

function cosine(a, b) {
  let dot = 0, na = 0, nb = 0;
  for (let i = 0; i < a.length; i++) {
    dot += a[i] * b[i];
    na += a[i] * a[i];
    nb += b[i] * b[i];
  }
  return dot / (Math.sqrt(na) * Math.sqrt(nb));
}

// ---- PUBLIC API ----
export async function addMemory(userId, text) {
  const db = load();
  if (!db[userId]) db[userId] = [];

  const emb = await embed(text);

  db[userId].push({
    text,
    emb
  });

  db[userId] = db[userId].slice(-100);
  save(db);
}

export async function getMemory(userId, query) {
  const db = load();
  const data = db[userId] || [];

  // if embeddings available
  if (openai) {
    const qEmb = await embed(query);

    return data
      .filter(x => x.emb)
      .map(x => ({
        text: x.text,
        score: cosine(x.emb, qEmb)
      }))
      .sort((a, b) => b.score - a.score)
      .slice(0, 5)
      .map(x => x.text);
  }

  // fallback (free)
  return data
    .map(x => ({ text: x.text, s: keywordScore(x.text, query) }))
    .sort((a, b) => b.s - a.s)
    .slice(0, 5)
    .map(x => x.text);
}



