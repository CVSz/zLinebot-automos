import torch
import torch.nn as nn
import torch.optim as optim

class Agent(nn.Module):
    def __init__(self):
        super().__init__()
        self.fc = nn.Sequential(
            nn.Linear(10, 64),
            nn.ReLU(),
            nn.Linear(64, 3)
        )

    def forward(self, x):
        return self.fc(x)

agent = Agent()
optimizer = optim.Adam(agent.parameters(), lr=0.001)

def train(state, reward):
    state = torch.tensor(state, dtype=torch.float32)
    output = agent(state)

    loss = (output.mean() - reward) ** 2
    optimizer.zero_grad()
    loss.backward()
    optimizer.step()



