✅ Sharpe Ratio


export function sharpe(returns) {
  const avg = returns.reduce((a,b)=>a+b,0)/returns.length;
  const std = Math.sqrt(returns.map(x => (x-avg)**2).reduce((a,b)=>a+b)/returns.length);
  return avg / std;
}



✅ Max Drawdown


export function drawdown(equity) {
  let peak = equity[0];
  let maxDD = 0;

  for (let val of equity) {
    if (val > peak) peak = val;
    const dd = (peak - val) / peak;
    if (dd > maxDD) maxDD = dd;
  }

  return maxDD;
}



✅ Win Rate


export function winRate(trades) {
  const wins = trades.filter(t => t.pnl > 0).length;
  return wins / trades.length;
}



