📄 trading/backtest.js


import { strategy } from "./strategy.js";

export function backtest(prices) {
  let balance = 1000;
  let position = 0;
  let trades = [];

  for (let i = 50; i < prices.length; i++) {
    const slice = prices.slice(i - 50, i);
    const price = prices[i];

    const signal = strategy(slice);

    if (signal === "BUY" && balance > 0) {
      position = balance / price;
      trades.push({ type: "BUY", price });
      balance = 0;
    }

    if (signal === "SELL" && position > 0) {
      balance = position * price;
      trades.push({ type: "SELL", price });
      position = 0;
    }
  }

  const finalValue = balance + position * prices[prices.length - 1];

  return {
    start: 1000,
    end: finalValue,
    profit: finalValue - 1000,
    trades
  };
}



