import WebSocket from "ws";

const feeds = {
  binance: "wss://stream.binance.com:9443/ws/btcusdt@bookTicker",
  bybit: "wss://stream.bybit.com/v5/public/spot"
};

let prices = {};

function connect(name, url) {
  const ws = new WebSocket(url);

  ws.on("message", (data) => {
    const msg = JSON.parse(data);

    // normalize
    prices[name] = {
      bid: parseFloat(msg.b || msg.data?.b),
      ask: parseFloat(msg.a || msg.data?.a)
    };

    checkArb();
  });
}

function checkArb() {
  const a = prices.binance;
  const b = prices.bybit;
  if (!a || !b) return;

  const spread = a.bid - b.ask;

  if (spread > 5) {
    console.log("⚡ ARB OPPORTUNITY", spread);
    // execute simultaneously
  }
}

connect("binance", feeds.binance);
connect("bybit", feeds.bybit);



