export function optimize(data, strategyFn) {
  let best = { profit: -Infinity };

  for (let rsiLow = 20; rsiLow <= 40; rsiLow += 5) {
    for (let rsiHigh = 60; rsiHigh <= 80; rsiHigh += 5) {

      const strat = (candle) => {
        if (candle.rsi < rsiLow) return "BUY";
        if (candle.rsi > rsiHigh) return "SELL";
        return "HOLD";
      };

      const engine = new BacktestEngine(strat, data);
      const res = engine.run();

      if (res.balance > best.profit) {
        best = { profit: res.balance, rsiLow, rsiHigh };
      }
    }
  }

  return best;
}



