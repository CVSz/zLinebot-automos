export async function bestExecution(exchanges, order) {
  let best = null;

  for (let ex of exchanges) {
    const price = await ex.getPrice();
    if (!best || price < best.price) {
      best = { ex, price };
    }
  }

  return best.ex.limitOrder(order.side, order.size, best.price);
}



