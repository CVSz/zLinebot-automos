#!/bin/bash
set -e

echo "🚀 FULL CODEX AUTO SETUP (zLinebot-automos)"

PROJECT_DIR="zLinebot-automos"

# ================================
# 0. CHECK REQUIREMENTS
# ================================
command -v git >/dev/null || { echo "❌ git not installed"; exit 1; }
command -v node >/dev/null || { echo "❌ node not installed"; exit 1; }
command -v npm >/dev/null || { echo "❌ npm not installed"; exit 1; }

# ================================
# 1. CLONE REPO
# ================================
if [ ! -d "$PROJECT_DIR" ]; then
  echo "📥 Cloning repository..."
  git clone https://github.com/CVSz/zLinebot-automos.git "$PROJECT_DIR"
fi

cd "$PROJECT_DIR" || exit

# ================================
# 2. DETECT PROJECT TYPE
# ================================
echo "🧠 Detecting project type..."

if [ -f package.json ]; then
  TYPE="node"
elif [ -f requirements.txt ]; then
  TYPE="python"
elif [ -f go.mod ]; then
  TYPE="go"
else
  TYPE="unknown"
fi

echo "📦 Project type: $TYPE"

# ================================
# 3. INSTALL DEPENDENCIES
# ================================
echo "📦 Installing dependencies..."

if [ "$TYPE" = "node" ]; then
  npm install --legacy-peer-deps
elif [ "$TYPE" = "python" ]; then
  pip install -r requirements.txt
elif [ "$TYPE" = "go" ]; then
  go mod tidy
else
  echo "⚠️ Unknown project type"
fi

# ================================
# 4. ENV FILE
# ================================
if [ ! -f .env ]; then
cat > .env <<'ENVEOF'
LINE_CHANNEL_ACCESS_TOKEN=PUT_YOUR_TOKEN
LINE_CHANNEL_SECRET=PUT_YOUR_SECRET
PORT=3000
NODE_ENV=production
ENVEOF
echo "🔑 .env created"
fi

# ================================
# 5. SMART ENTRY DETECTION
# ================================
ENTRY=""

if [ -f package.json ]; then
  ENTRY=$(node -e "try{console.log(require('./package.json').main||'')}catch(e){}")
fi

if [ -z "$ENTRY" ]; then
  for f in index.js app.js server.js main.js; do
    [ -f "$f" ] && ENTRY="$f" && break
  done
fi

echo "🎯 Entry point: ${ENTRY:-NOT FOUND}"

# ================================
# 6. CREATE RUN SCRIPT
# ================================
cat > run.sh <<EOF
#!/bin/bash
echo "🚀 Starting bot..."

if npm run | grep -q "start"; then
  npm start
elif [ -f "$ENTRY" ]; then
  node "$ENTRY"
else
  echo "❌ No valid entry found"
fi
EOF

chmod +x run.sh

# ================================
# 7. INSTALL CODEX (SAFE)
# ================================
echo "⚡ Installing Codex..."
npm install -g @openai/codex || true

# ================================
# 8. CONFIGURE CODEX (SAFE WRITE)
# ================================
mkdir -p ~/.codex

cat > ~/.codex/config.toml <<'EOF'
model = "gpt-5-codex"
model_reasoning_effort = "medium"

approval_policy = "auto-edit"
sandbox_mode = "workspace-write"

[features]
multi_agent = true
self_healing = true
EOF

# ================================
# 9. CHECK API KEY
# ================================
if [ -z "$OPENAI_API_KEY" ]; then
  echo "⚠️ OPENAI_API_KEY not set"
  echo "👉 export OPENAI_API_KEY=your_key"
fi

# ================================
# 10. RUN CODEX (FIXED)
# ================================
echo "🤖 Running Codex analysis..."

codex "Analyze this LINE bot project, fix errors, optimize and prepare production"

# ================================
# 11. START BOT
# ================================
echo "🚀 Launching bot..."
./run.sh

echo "✅ DONE"



