📄 smartMemory.js


import fs from "fs";

const FILE = "./memory.json";

function load() {
  if (!fs.existsSync(FILE)) return {};
  return JSON.parse(fs.readFileSync(FILE));
}

function save(data) {
  fs.writeFileSync(FILE, JSON.stringify(data, null, 2));
}

function score(text, query) {
  let s = 0;
  query.split(" ").forEach(w => {
    if (text.toLowerCase().includes(w.toLowerCase())) s++;
  });
  return s;
}

export function addMemory(userId, text) {
  const db = load();
  if (!db[userId]) db[userId] = [];

  db[userId].push(text);
  db[userId] = db[userId].slice(-50);

  save(db);
}

export function getMemory(userId, query) {
  const db = load();
  const data = db[userId] || [];

  return data
    .map(t => ({ t, s: score(t, query) }))
    .sort((a, b) => b.s - a.s)
    .slice(0, 5)
    .map(x => x.t);
}


👉 Works like mini vector DB (no API cost)



