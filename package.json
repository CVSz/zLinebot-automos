{
  "name": "zlinebot-automos",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "landing"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "build:frontend": "npm --workspace frontend run build",
    "dev:landing": "npm --workspace landing run dev",
    "build:landing": "npm --workspace landing run build",
    "stack:up": "docker compose up -d --build",
    "stack:down": "docker compose down"
  }
}
